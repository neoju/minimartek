{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "migrate:latest": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts migrate:latest",
    "migrate:make": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts migrate:make",
    "seed:run": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts seed:run",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@repo/dto": "workspace:*",
    "@repo/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.75.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.8",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mock-knex": "^0.4.8",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "mock-knex": "^0.4.13",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "5.9.2"
  }
}
