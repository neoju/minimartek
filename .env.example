# ── Docker Compose variables ───────────────────────────────────────────────────
# Copy to .env before running `make start` (done automatically by Makefile).

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mini_martech
DB_PORT=5432

# Backend service port (host-side)
PORT=3001

# JWT
JWT_SECRET=change-me-in-production

# Frontend service port (host-side)
FE_PORT=8080
VITE_API_URL=http://localhost:3001
